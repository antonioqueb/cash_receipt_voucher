<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_cash_receipt">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <t t-set="address" t-value="False"/>
                    <t t-set="information_block" t-value="False"/>

                    <div class="page" style="font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; font-size: 10px; color: #000; line-height: 1.25;">

                        <!-- ============ TÍTULO ============ -->
                        <div class="row border-bottom pb-2 mb-2" style="border-color: #000 !important; align-items: center;">
                            <div class="col-8">
                                <h4 class="text-uppercase mb-0" style="font-weight: 800; letter-spacing: 1px;">
                                    Recibo de Pago en Efectivo
                                    <span t-field="doc.name" style="margin-left: 10px; color: #333;"/>
                                </h4>
                            </div>
                            <div class="col-4 text-end">
                                <div style="font-size: 14px; color: #505050; margin-top: 4px;">
                                    Impreso: <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y %H:%M')"/>
                                </div>
                            </div>
                        </div>

                        <!-- ============ INFORMACIÓN GENERAL (3 columnas) ============ -->
                        <t t-set="state_label" t-value="'Borrador' if doc.state == 'draft' else 'Pago registrado' if doc.state == 'paid' else 'Cancelado' if doc.state == 'cancelled' else doc.state"/>
                        <div style="margin-bottom: 12px;">
                            <table style="font-size: 9px; width: 100%; border-collapse: collapse; border: 1px solid #d8d8d8 !important; table-layout: fixed;">
                                <colgroup>
                                    <col style="width: 38%;"/>
                                    <col style="width: 32%;"/>
                                    <col style="width: 30%;"/>
                                </colgroup>
                                <thead>
                                    <tr>
                                        <th style="padding: 6px 8px; text-align: left; font-weight: 800; font-size: 9.5px; text-transform: uppercase; letter-spacing: 0.5px; background-color: #f2f2f2; color: #222; border: 1px solid #d8d8d8 !important;">Cliente</th>
                                        <th style="padding: 6px 8px; text-align: left; font-weight: 800; font-size: 9.5px; text-transform: uppercase; letter-spacing: 0.5px; background-color: #f2f2f2; color: #222; border: 1px solid #d8d8d8 !important;">Detalles del Recibo</th>
                                        <th style="padding: 6px 8px; text-align: left; font-weight: 800; font-size: 9.5px; text-transform: uppercase; letter-spacing: 0.5px; background-color: #f2f2f2; color: #222; border: 1px solid #d8d8d8 !important;">Estado del Documento</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <!-- CLIENTE -->
                                        <td style="vertical-align: top; padding: 6px 8px; border: 1px solid #d8d8d8 !important; overflow-wrap: anywhere; word-break: break-word;">
                                            <span style="font-weight: bold; font-size: 11px;" t-field="doc.partner_id.name"/>
                                            <span t-if="doc.partner_id.vat" style="display: block; font-size: 8.5px; color: #555; margin-top: 2px;">RFC: <span t-field="doc.partner_id.vat"/></span>
                                            <span t-if="doc.partner_id.street" style="display: block; font-size: 9px; color: #333; margin-top: 3px; line-height: 1.25;">
                                                <span t-field="doc.partner_id.street"/><t t-if="doc.partner_id.city">, <span t-field="doc.partner_id.city"/></t><t t-if="doc.partner_id.state_id">, <span t-field="doc.partner_id.state_id.name"/></t>
                                            </span>
                                            <span t-if="doc.partner_id.phone" style="display: block; font-size: 9px; color: #555; margin-top: 2px;">Tel: <span t-field="doc.partner_id.phone"/></span>
                                        </td>

                                        <!-- DETALLES DEL RECIBO -->
                                        <td style="vertical-align: top; padding: 0; border: 1px solid #d8d8d8 !important;">
                                            <div style="display: table; width: 100%; table-layout: fixed; border-bottom: 1px solid #d8d8d8 !important;">
                                                <div style="display: table-cell; width: 45%; padding: 5px 8px; color: #555; text-transform: uppercase; font-size: 8.5px; letter-spacing: 0.3px; border-right: 1px solid #d8d8d8 !important;">Fecha</div>
                                                <div style="display: table-cell; padding: 5px 8px; font-weight: 600;"><span t-field="doc.date" t-options="{'format': 'dd/MM/yyyy HH:mm'}"/></div>
                                            </div>
                                            <div style="display: table; width: 100%; table-layout: fixed; border-bottom: 1px solid #d8d8d8 !important;">
                                                <div style="display: table-cell; width: 45%; padding: 5px 8px; color: #555; text-transform: uppercase; font-size: 8.5px; letter-spacing: 0.3px; border-right: 1px solid #d8d8d8 !important;">Recibido por</div>
                                                <div style="display: table-cell; padding: 5px 8px; font-weight: 600; overflow-wrap: anywhere; word-break: break-word;"><span t-field="doc.received_by.name"/></div>
                                            </div>
                                            <div style="display: table; width: 100%; table-layout: fixed; border-bottom: 1px solid #d8d8d8 !important;">
                                                <div style="display: table-cell; width: 45%; padding: 5px 8px; color: #555; text-transform: uppercase; font-size: 8.5px; letter-spacing: 0.3px; border-right: 1px solid #d8d8d8 !important;">Forma de pago</div>
                                                <div style="display: table-cell; padding: 5px 8px; font-weight: 600;">Efectivo</div>
                                            </div>
                                            <div style="display: table; width: 100%; table-layout: fixed;">
                                                <div style="display: table-cell; width: 45%; padding: 5px 8px; color: #555; text-transform: uppercase; font-size: 8.5px; letter-spacing: 0.3px; border-right: 1px solid #d8d8d8 !important;">Divisa</div>
                                                <div style="display: table-cell; padding: 5px 8px; font-weight: 600;"><span t-field="doc.currency_id.name"/></div>
                                            </div>
                                        </td>

                                        <!-- ESTADO -->
                                        <td style="vertical-align: top; padding: 0; border: 1px solid #d8d8d8 !important;">
                                            <div style="display: table; width: 100%; table-layout: fixed; border-bottom: 1px solid #d8d8d8 !important;">
                                                <div style="display: table-cell; width: 45%; padding: 5px 8px; color: #555; text-transform: uppercase; font-size: 8.5px; letter-spacing: 0.3px; border-right: 1px solid #d8d8d8 !important;">Estado</div>
                                                <div style="display: table-cell; padding: 5px 8px; text-align: right; font-weight: 700;"><span t-esc="state_label"/></div>
                                            </div>
                                            <div style="display: table; width: 100%; table-layout: fixed;">
                                                <div style="display: table-cell; width: 45%; padding: 5px 8px; color: #555; text-transform: uppercase; font-size: 8.5px; letter-spacing: 0.3px; border-right: 1px solid #d8d8d8 !important;">Recibo No.</div>
                                                <div style="display: table-cell; padding: 5px 8px; text-align: right; font-weight: 600;"><span t-field="doc.name"/></div>
                                            </div>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <!-- ============ MONTO RECIBIDO ============ -->
                        <div style="margin-top: 14px; border: 1px solid #2f2f2f; page-break-inside: avoid;">
                            <div style="background-color: #2f2f2f; padding: 5px 12px;">
                                <span style="color: #fff; font-size: 10px; text-transform: uppercase; letter-spacing: 2px; font-weight: 700;">Monto recibido</span>
                            </div>
                            <div style="padding: 14px 18px; text-align: center;">
                                <span style="font-size: 30px; font-weight: 900; letter-spacing: 1px;">
                                    <span t-field="doc.amount" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                </span>
                            </div>
                        </div>

                        <!-- ============ PEDIDOS ASOCIADOS ============ -->
                        <t t-if="doc.sale_order_ids">
                            <div style="margin-top: 14px; margin-bottom: 5px; width: 100%; page-break-inside: avoid;">
                                <span style="font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; font-size: 12px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; color: #222;">Pedidos de venta asociados</span>
                            </div>
                            <table class="table table-sm" style="width: 100%; font-size: 9px; border-collapse: collapse; table-layout: fixed;">
                                <thead>
                                    <tr style="background-color: #2f2f2f; color: #fff;">
                                        <th style="color: #fff; width: 40%; font-weight: bold;">Pedido</th>
                                        <th class="text-center" style="color: #fff; width: 30%; font-weight: bold;">Fecha</th>
                                        <th class="text-end" style="color: #fff; width: 30%; font-weight: bold;">Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="doc.sale_order_ids" t-as="order">
                                        <tr style="page-break-inside: avoid;">
                                            <td class="align-middle" style="overflow-wrap: anywhere; word-break: break-word;"><strong t-field="order.name"/></td>
                                            <td class="text-center align-middle"><span t-field="order.date_order" t-options="{'format': 'dd/MM/yyyy'}"/></td>
                                            <td class="text-end align-middle" style="white-space: nowrap;"><span t-field="order.amount_total" t-options="{'widget': 'monetary', 'display_currency': order.currency_id}"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                                <tfoot>
                                    <tr style="background-color: #f2f2f2; color: #222;">
                                        <td colspan="2" class="text-end" style="padding: 4px 8px; font-weight: 800; text-transform: uppercase; border: 1px solid #d8d8d8;">Total de pedidos</td>
                                        <td class="text-end" style="padding: 4px 8px; font-weight: 800; border: 1px solid #d8d8d8; white-space: nowrap;"><span t-field="doc.total_orders_amount" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </t>

                        <!-- ============ CONCEPTO / NOTAS ============ -->
                        <t t-if="doc.notes">
                            <div style="margin-top: 14px; margin-bottom: 5px; width: 100%; page-break-inside: avoid;">
                                <span style="font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; font-size: 12px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; color: #222;">Concepto / Notas</span>
                            </div>
                            <div style="border: 1px solid #d8d8d8; padding: 8px; background-color: #fafafa; white-space: pre-line; font-size: 9.5px; line-height: 1.35;">
                                <span t-field="doc.notes"/>
                            </div>
                        </t>

                        <!-- ============ PAGO FORMAL VINCULADO ============ -->
                        <t t-if="doc.payment_id">
                            <div style="margin-top: 14px;">
                                <table style="font-size: 9px; width: 100%; border-collapse: collapse; border: 1px solid #d8d8d8 !important; table-layout: fixed;">
                                    <tr>
                                        <td style="width: 22%; padding: 5px 8px; color: #555; text-transform: uppercase; font-size: 8.5px; background-color: #f2f2f2; border: 1px solid #d8d8d8 !important;">Pago formal vinculado</td>
                                        <td style="width: 38%; padding: 5px 8px; font-weight: 700; border: 1px solid #d8d8d8 !important;"><span t-field="doc.payment_id.name"/></td>
                                        <td style="width: 15%; padding: 5px 8px; color: #555; text-transform: uppercase; font-size: 8.5px; background-color: #f2f2f2; border: 1px solid #d8d8d8 !important;">Fecha</td>
                                        <td style="width: 25%; padding: 5px 8px; font-weight: 600; border: 1px solid #d8d8d8 !important;"><span t-field="doc.payment_id.date"/></td>
                                    </tr>
                                </table>
                            </div>
                        </t>

                        <!-- ============ FIRMAS ============ -->
                        <div style="margin-top: 45px; width: 100%; page-break-inside: avoid;">
                            <div class="row">
                                <div class="col-1"></div>
                                <div class="col-4 text-center">
                                    <t t-if="doc.signature">
                                        <div style="min-height: 55px;">
                                            <img t-att-src="image_data_uri(doc.signature)" style="max-height: 55px; max-width: 170px;"/>
                                        </div>
                                    </t>
                                    <t t-else=""><div style="min-height: 55px;"/></t>
                                    <div style="border-top: 1px solid #000; padding-top: 5px;">
                                        <strong t-if="doc.signature_name" style="display: block; font-size: 10px;"><span t-field="doc.signature_name"/></strong>
                                        <strong style="font-size: 9px; text-transform: uppercase;">Quien recibe el pago</strong>
                                    </div>
                                </div>
                                <div class="col-2"></div>
                                <div class="col-4 text-center">
                                    <div style="min-height: 55px;"/>
                                    <div style="border-top: 1px solid #000; padding-top: 5px;">
                                        <strong style="font-size: 9px; text-transform: uppercase;">Firma / Sello del cliente</strong>
                                    </div>
                                </div>
                                <div class="col-1"></div>
                            </div>
                        </div>

                        <!-- ============ AVISO LEGAL ============ -->
                        <div style="margin-top: 22px; border: 1px solid #ccc; padding: 8px; background-color: #fafafa; font-size: 9px; color: #555; line-height: 1.4;">
                            <strong style="color: #333;">AVISO IMPORTANTE:</strong>
                            Este recibo ampara la recepción del pago en efectivo aquí indicado.
                            <strong>No sustituye una factura ni un Comprobante Fiscal Digital por Internet (CFDI).</strong>
                            Para cualquier aclaración, contacte a su asesor de ventas.
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>
