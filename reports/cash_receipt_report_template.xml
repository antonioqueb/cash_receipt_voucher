<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_cash_receipt">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: Arial, sans-serif; color: #000; font-size: 10px; line-height: 1.3;">

                        <!-- ENCABEZADO -->
                        <div style="border-bottom: 2px solid #000; padding-bottom: 6px; margin-bottom: 10px;">
                            <div class="row">
                                <div class="col-8">
                                    <strong style="font-size: 15px; letter-spacing: 0.5px;">RECIBO DE PAGO EN EFECTIVO</strong>
                                    <br/>
                                    <span style="font-size: 8px; color: #555;">Comprobante provisional · No sustituye CFDI</span>
                                </div>
                                <div class="col-4 text-end">
                                    <strong style="font-size: 14px;"><span t-field="doc.name"/></strong>
                                    <br/>
                                    <span style="font-size: 8px;">
                                        <span t-field="doc.date" t-options="{'format': 'dd/MM/yyyy HH:mm'}"/>
                                    </span>
                                </div>
                            </div>
                        </div>

                        <!-- ESTADO -->
                        <t t-if="doc.state == 'draft'">
                            <div style="border: 1px dashed #000; padding: 4px 8px; margin-bottom: 8px; font-size: 9px; text-align: center;">
                                <strong>BORRADOR — NO VÁLIDO</strong>
                            </div>
                        </t>
                        <t t-if="doc.state == 'delivered'">
                            <div style="border: 1px solid #000; padding: 4px 8px; margin-bottom: 8px; font-size: 9px; text-align: center;">
                                <strong>ENTREGADO — PENDIENTE DE REGISTRO FORMAL</strong>
                            </div>
                        </t>
                        <t t-if="doc.state == 'paid'">
                            <div style="border: 1px solid #000; padding: 4px 8px; margin-bottom: 8px; font-size: 9px; text-align: center;">
                                <strong>✓ PAGO REGISTRADO</strong>
                            </div>
                        </t>
                        <t t-if="doc.state == 'cancelled'">
                            <div style="border: 1px solid #000; padding: 4px 8px; margin-bottom: 8px; font-size: 9px; text-align: center;">
                                <strong>✗ CANCELADO</strong>
                            </div>
                        </t>

                        <!-- DATOS CLIENTE + DETALLES -->
                        <div class="row" style="margin-bottom: 8px;">
                            <div class="col-6">
                                <table style="width: 100%; font-size: 10px;">
                                    <tr>
                                        <td style="padding: 1px 0; color: #555; width: 30%;">Cliente:</td>
                                        <td style="padding: 1px 0; font-weight: 700;"><span t-field="doc.partner_id.name"/></td>
                                    </tr>
                                    <t t-if="doc.partner_id.vat">
                                        <tr>
                                            <td style="padding: 1px 0; color: #555;">RFC:</td>
                                            <td style="padding: 1px 0;"><span t-field="doc.partner_id.vat"/></td>
                                        </tr>
                                    </t>
                                    <t t-if="doc.partner_id.street">
                                        <tr>
                                            <td style="padding: 1px 0; color: #555;">Dirección:</td>
                                            <td style="padding: 1px 0; font-size: 9px;">
                                                <span t-field="doc.partner_id.street"/>
                                                <t t-if="doc.partner_id.city">, <span t-field="doc.partner_id.city"/></t>
                                            </td>
                                        </tr>
                                    </t>
                                </table>
                            </div>
                            <div class="col-6">
                                <table style="width: 100%; font-size: 10px;">
                                    <tr>
                                        <td style="padding: 1px 0; color: #555; width: 40%;">Recibido por:</td>
                                        <td style="padding: 1px 0;"><span t-field="doc.received_by.name"/></td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 1px 0; color: #555;">Forma de pago:</td>
                                        <td style="padding: 1px 0;">Efectivo</td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 1px 0; color: #555;">Divisa:</td>
                                        <td style="padding: 1px 0;"><span t-field="doc.currency_id.name"/></td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- MONTO -->
                        <div style="border: 2px solid #000; padding: 10px; text-align: center; margin-bottom: 10px;">
                            <span style="font-size: 8px; text-transform: uppercase; letter-spacing: 1px; color: #555;">Monto Recibido</span>
                            <br/>
                            <strong style="font-size: 28px; letter-spacing: 1px;">
                                <span t-field="doc.amount" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                            </strong>
                        </div>

                        <!-- PEDIDOS -->
                        <t t-if="doc.sale_order_ids">
                            <table style="width: 100%; border-collapse: collapse; margin-bottom: 10px; font-size: 10px;">
                                <thead>
                                    <tr>
                                        <th style="border-bottom: 2px solid #000; padding: 3px 6px; text-align: left; font-size: 9px; text-transform: uppercase;">Pedido</th>
                                        <th style="border-bottom: 2px solid #000; padding: 3px 6px; text-align: left; font-size: 9px; text-transform: uppercase;">Fecha</th>
                                        <th style="border-bottom: 2px solid #000; padding: 3px 6px; text-align: right; font-size: 9px; text-transform: uppercase;">Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="doc.sale_order_ids" t-as="order">
                                        <tr>
                                            <td style="padding: 3px 6px; border-bottom: 1px solid #ccc;"><span t-field="order.name"/></td>
                                            <td style="padding: 3px 6px; border-bottom: 1px solid #ccc; color: #555;"><span t-field="order.date_order" t-options="{'format': 'dd/MM/yyyy'}"/></td>
                                            <td style="padding: 3px 6px; border-bottom: 1px solid #ccc; text-align: right;"><span t-field="order.amount_total" t-options="{'widget': 'monetary', 'display_currency': order.currency_id}"/></td>
                                        </tr>
                                    </t>
                                </tbody>
                                <tfoot>
                                    <tr>
                                        <td colspan="2" style="padding: 3px 6px; border-top: 2px solid #000; font-weight: 700;">Total Pedidos</td>
                                        <td style="padding: 3px 6px; border-top: 2px solid #000; text-align: right; font-weight: 700;">
                                            <span t-field="doc.total_orders_amount" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                        </td>
                                    </tr>
                                </tfoot>
                            </table>
                        </t>

                        <!-- CONCEPTO -->
                        <t t-if="doc.notes">
                            <div style="margin-bottom: 10px;">
                                <strong style="font-size: 9px; text-transform: uppercase;">Concepto:</strong>
                                <div style="border: 1px solid #ccc; padding: 4px 8px; margin-top: 2px; font-size: 10px;">
                                    <span t-field="doc.notes"/>
                                </div>
                            </div>
                        </t>

                        <!-- PAGO REGISTRADO -->
                        <t t-if="doc.payment_id">
                            <div style="border: 1px solid #000; padding: 4px 8px; margin-bottom: 10px; font-size: 9px;">
                                <strong>Pago registrado:</strong>
                                <span t-field="doc.payment_id.name"/> — <span t-field="doc.payment_id.date"/>
                            </div>
                        </t>

                        <!-- FIRMAS -->
                        <div class="row" style="margin-top: 25px;">
                            <div class="col-6 text-center">
                                <t t-if="doc.signature">
                                    <div style="min-height: 50px;">
                                        <img t-att-src="image_data_uri(doc.signature)" style="max-height: 50px; max-width: 150px;"/>
                                    </div>
                                </t>
                                <t t-else="">
                                    <div style="min-height: 50px;"/>
                                </t>
                                <div style="border-top: 1px solid #000; width: 180px; margin: 0 auto; padding-top: 4px;">
                                    <t t-if="doc.signature_name">
                                        <span style="font-size: 9px; font-weight: 600;"><span t-field="doc.signature_name"/></span><br/>
                                    </t>
                                    <span style="font-size: 8px; color: #555; text-transform: uppercase;">Quien Recibe</span>
                                </div>
                            </div>
                            <div class="col-6 text-center">
                                <div style="min-height: 50px;"/>
                                <div style="border-top: 1px solid #000; width: 180px; margin: 0 auto; padding-top: 4px;">
                                    <span style="font-size: 8px; color: #555; text-transform: uppercase;">Firma / Sello del Cliente</span>
                                </div>
                            </div>
                        </div>

                        <!-- AVISO -->
                        <div style="margin-top: 15px; border-top: 1px solid #999; padding-top: 6px; font-size: 8px; color: #666; line-height: 1.4;">
                            <strong>AVISO:</strong> Comprobante provisional de recepción de efectivo.
                            No sustituye factura ni CFDI. El pago será formalizado en el sistema contable.
                        </div>

                        <!-- PIE -->
                        <div class="text-center" style="margin-top: 6px; font-size: 7px; color: #999;">
                            <span t-field="doc.name"/> · <span t-field="doc.company_id.name"/> ·
                            <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y %H:%M')"/>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>