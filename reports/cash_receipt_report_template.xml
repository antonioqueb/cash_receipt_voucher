<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_cash_receipt">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: 'Segoe UI', Arial, sans-serif; color: #1a1a1a; font-size: 12px; line-height: 1.5;">

                        <!-- ═══════ ENCABEZADO ═══════ -->
                        <div style="text-align: center; padding: 15px 0 12px; border-top: 6px solid #000; border-bottom: 1px solid #000;">
                            <div style="font-size: 10px; text-transform: uppercase; letter-spacing: 4px; color: #666; margin-bottom: 4px;">
                                Comprobante Provisional
                            </div>
                            <h1 style="font-size: 22px; font-weight: 800; margin: 0; letter-spacing: 2px; text-transform: uppercase;">
                                Recibo de Pago en Efectivo
                            </h1>
                        </div>

                        <!-- Número + Fecha -->
                        <div class="row" style="margin-top: 12px; margin-bottom: 15px;">
                            <div class="col-6">
                                <table style="font-size: 12px;">
                                    <tr>
                                        <td style="padding: 2px 10px 2px 0; color: #777; font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px; vertical-align: middle;">Recibo No.</td>
                                        <td style="padding: 2px 0; font-size: 18px; font-weight: 800; letter-spacing: 1px;"><span t-field="doc.name"/></td>
                                    </tr>
                                </table>
                            </div>
                            <div class="col-6 text-end">
                                <table style="font-size: 12px; margin-left: auto;">
                                    <tr>
                                        <td style="padding: 2px 10px 2px 0; color: #777; font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px; vertical-align: middle;">Fecha</td>
                                        <td style="padding: 2px 0; font-weight: 600;">
                                            <span t-field="doc.date" t-options="{'format': 'dd/MM/yyyy  ·  HH:mm hrs'}"/>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <!-- ═══════ ESTADO ═══════ -->
                        <t t-if="doc.state == 'draft'">
                            <div style="border: 2px dashed #999; padding: 8px; text-align: center; margin-bottom: 18px;">
                                <span style="font-size: 11px; text-transform: uppercase; letter-spacing: 2px; color: #666; font-weight: 700;">▫ Borrador — Documento no válido ▫</span>
                            </div>
                        </t>
                        <t t-if="doc.state == 'delivered'">
                            <div style="border: 2px solid #444; padding: 8px; text-align: center; margin-bottom: 18px; background: #f5f5f5;">
                                <span style="font-size: 11px; text-transform: uppercase; letter-spacing: 2px; font-weight: 700;">Entregado — Pendiente de Registro Formal</span>
                            </div>
                        </t>
                        <t t-if="doc.state == 'paid'">
                            <div style="border: 2px solid #000; padding: 8px; text-align: center; margin-bottom: 18px;">
                                <span style="font-size: 11px; text-transform: uppercase; letter-spacing: 2px; font-weight: 700;">✓ Pago Registrado en el Sistema</span>
                            </div>
                        </t>
                        <t t-if="doc.state == 'cancelled'">
                            <div style="border: 2px solid #000; padding: 8px; text-align: center; margin-bottom: 18px;">
                                <span style="font-size: 11px; text-transform: uppercase; letter-spacing: 2px; font-weight: 700; text-decoration: line-through;">Cancelado</span>
                            </div>
                        </t>

                        <!-- ═══════ DATOS PRINCIPALES ═══════ -->
                        <div class="row" style="margin-bottom: 20px;">
                            <!-- Cliente -->
                            <div class="col-6">
                                <div style="border: 1px solid #ccc; padding: 14px 16px; height: 100%;">
                                    <div style="font-size: 9px; text-transform: uppercase; letter-spacing: 2px; color: #999; margin-bottom: 6px; font-weight: 600;">Datos del Cliente</div>
                                    <div style="font-size: 15px; font-weight: 700; margin-bottom: 4px;">
                                        <span t-field="doc.partner_id.name"/>
                                    </div>
                                    <t t-if="doc.partner_id.vat">
                                        <div style="font-size: 11px; color: #444; margin-bottom: 2px;">
                                            <span style="color: #999;">RFC:</span> <span t-field="doc.partner_id.vat"/>
                                        </div>
                                    </t>
                                    <t t-if="doc.partner_id.street">
                                        <div style="font-size: 10px; color: #777; margin-top: 4px; line-height: 1.3;">
                                            <span t-field="doc.partner_id.street"/>
                                            <t t-if="doc.partner_id.city">, <span t-field="doc.partner_id.city"/></t>
                                            <t t-if="doc.partner_id.state_id">, <span t-field="doc.partner_id.state_id.name"/></t>
                                        </div>
                                    </t>
                                    <t t-if="doc.partner_id.phone">
                                        <div style="font-size: 10px; color: #777; margin-top: 2px;">
                                            Tel: <span t-field="doc.partner_id.phone"/>
                                        </div>
                                    </t>
                                </div>
                            </div>
                            <!-- Detalles del recibo -->
                            <div class="col-6">
                                <div style="border: 1px solid #ccc; padding: 14px 16px; height: 100%;">
                                    <div style="font-size: 9px; text-transform: uppercase; letter-spacing: 2px; color: #999; margin-bottom: 6px; font-weight: 600;">Detalles del Recibo</div>
                                    <table style="width: 100%; font-size: 12px;">
                                        <tr>
                                            <td style="padding: 3px 0; color: #777; width: 45%;">Recibido por:</td>
                                            <td style="padding: 3px 0; font-weight: 600;"><span t-field="doc.received_by.name"/></td>
                                        </tr>
                                        <tr>
                                            <td style="padding: 3px 0; color: #777;">Forma de pago:</td>
                                            <td style="padding: 3px 0; font-weight: 600;">Efectivo</td>
                                        </tr>
                                        <tr>
                                            <td style="padding: 3px 0; color: #777;">Divisa:</td>
                                            <td style="padding: 3px 0; font-weight: 600;"><span t-field="doc.currency_id.name"/></td>
                                        </tr>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <!-- ═══════ MONTO PRINCIPAL ═══════ -->
                        <div style="border: 3px solid #000; margin-bottom: 22px;">
                            <div style="background: #000; padding: 6px 16px;">
                                <span style="color: #fff; font-size: 10px; text-transform: uppercase; letter-spacing: 3px; font-weight: 600;">Monto Recibido</span>
                            </div>
                            <div style="padding: 18px 20px; text-align: center;">
                                <span style="font-size: 36px; font-weight: 900; letter-spacing: 2px;">
                                    <span t-field="doc.amount" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                </span>
                            </div>
                        </div>

                        <!-- ═══════ PEDIDOS ASOCIADOS ═══════ -->
                        <t t-if="doc.sale_order_ids">
                            <div style="margin-bottom: 22px;">
                                <div style="font-size: 9px; text-transform: uppercase; letter-spacing: 2px; color: #999; font-weight: 600; margin-bottom: 8px; padding-bottom: 4px; border-bottom: 2px solid #000;">
                                    Pedidos de Venta Asociados
                                </div>
                                <table style="width: 100%; border-collapse: collapse;">
                                    <thead>
                                        <tr>
                                            <th style="background: #f0f0f0; padding: 7px 10px; text-align: left; font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px; border-bottom: 1px solid #999;">Pedido</th>
                                            <th style="background: #f0f0f0; padding: 7px 10px; text-align: left; font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px; border-bottom: 1px solid #999;">Fecha</th>
                                            <th style="background: #f0f0f0; padding: 7px 10px; text-align: right; font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px; border-bottom: 1px solid #999;">Total</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="doc.sale_order_ids" t-as="order">
                                            <tr>
                                                <td style="padding: 7px 10px; border-bottom: 1px solid #ddd; font-weight: 600;">
                                                    <span t-field="order.name"/>
                                                </td>
                                                <td style="padding: 7px 10px; border-bottom: 1px solid #ddd; color: #555;">
                                                    <span t-field="order.date_order" t-options="{'format': 'dd/MM/yyyy'}"/>
                                                </td>
                                                <td style="padding: 7px 10px; border-bottom: 1px solid #ddd; text-align: right; font-weight: 600;">
                                                    <span t-field="order.amount_total" t-options="{'widget': 'monetary', 'display_currency': order.currency_id}"/>
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                    <tfoot>
                                        <tr>
                                            <td colspan="2" style="padding: 8px 10px; border-top: 2px solid #000; font-weight: 800; font-size: 12px;">
                                                Total de Pedidos
                                            </td>
                                            <td style="padding: 8px 10px; border-top: 2px solid #000; text-align: right; font-weight: 800; font-size: 13px;">
                                                <span t-field="doc.total_orders_amount" t-options="{'widget': 'monetary', 'display_currency': doc.currency_id}"/>
                                            </td>
                                        </tr>
                                    </tfoot>
                                </table>
                            </div>
                        </t>

                        <!-- ═══════ CONCEPTO ═══════ -->
                        <t t-if="doc.notes">
                            <div style="margin-bottom: 22px;">
                                <div style="font-size: 9px; text-transform: uppercase; letter-spacing: 2px; color: #999; font-weight: 600; margin-bottom: 6px;">
                                    Concepto / Notas
                                </div>
                                <div style="border: 1px solid #ccc; border-left: 4px solid #000; padding: 10px 14px; font-size: 12px; line-height: 1.5;">
                                    <span t-field="doc.notes"/>
                                </div>
                            </div>
                        </t>

                        <!-- ═══════ PAGO REGISTRADO ═══════ -->
                        <t t-if="doc.payment_id">
                            <div style="border: 1px solid #000; padding: 10px 14px; margin-bottom: 22px;">
                                <div style="font-size: 9px; text-transform: uppercase; letter-spacing: 2px; font-weight: 600; margin-bottom: 4px;">
                                    Pago Formal Vinculado
                                </div>
                                <table style="font-size: 12px;">
                                    <tr>
                                        <td style="padding: 2px 12px 2px 0; color: #777;">Referencia:</td>
                                        <td style="font-weight: 700;"><span t-field="doc.payment_id.name"/></td>
                                    </tr>
                                    <tr>
                                        <td style="padding: 2px 12px 2px 0; color: #777;">Fecha:</td>
                                        <td style="font-weight: 600;"><span t-field="doc.payment_id.date"/></td>
                                    </tr>
                                </table>
                            </div>
                        </t>

                        <!-- ═══════ FIRMAS ═══════ -->
                        <div class="row" style="margin-top: 40px; margin-bottom: 25px;">
                            <div class="col-6 text-center">
                                <div style="margin: 0 20px;">
                                    <t t-if="doc.signature">
                                        <div style="min-height: 70px; display: flex; align-items: flex-end; justify-content: center;">
                                            <img t-att-src="image_data_uri(doc.signature)" style="max-height: 65px; max-width: 170px;"/>
                                        </div>
                                    </t>
                                    <t t-else="">
                                        <div style="min-height: 70px;"/>
                                    </t>
                                    <div style="border-top: 2px solid #000; padding-top: 8px; margin-top: 3px;">
                                        <t t-if="doc.signature_name">
                                            <div style="font-weight: 700; font-size: 11px; margin-bottom: 2px;">
                                                <span t-field="doc.signature_name"/>
                                            </div>
                                        </t>
                                        <div style="font-size: 9px; color: #777; text-transform: uppercase; letter-spacing: 1.5px;">
                                            Quien Recibe el Pago
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="col-6 text-center">
                                <div style="margin: 0 20px;">
                                    <div style="min-height: 70px;"/>
                                    <div style="border-top: 2px solid #000; padding-top: 8px; margin-top: 3px;">
                                        <div style="font-size: 9px; color: #777; text-transform: uppercase; letter-spacing: 1.5px;">
                                            Firma / Sello del Cliente
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- ═══════ AVISO LEGAL ═══════ -->
                        <div style="margin-top: 25px; padding: 10px 14px; border: 1px solid #ccc; background: #fafafa; font-size: 9px; color: #666; line-height: 1.5;">
                            <strong style="color: #333;">AVISO IMPORTANTE:</strong>
                            Este documento es un comprobante provisional de recepción de pago en efectivo.
                            <strong>No sustituye una factura ni un Comprobante Fiscal Digital por Internet (CFDI).</strong>
                            El pago aquí consignado será registrado formalmente en el sistema contable de la empresa.
                            Para cualquier aclaración, contacte a su asesor de ventas.
                        </div>

                        <!-- ═══════ PIE ═══════ -->
                        <div class="text-center" style="margin-top: 10px; font-size: 8px; color: #aaa; letter-spacing: 0.5px;">
                            <span t-field="doc.name"/>  ·  <span t-field="doc.company_id.name"/>  ·
                            Generado el <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y a las %H:%M hrs')"/>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>