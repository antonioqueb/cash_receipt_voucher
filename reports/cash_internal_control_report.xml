<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Acción de reporte PDF: Control Interno de Efectivo.
         SIN binding al menú Imprimir (para no exponerlo a perfiles sin permiso):
         se imprime desde un botón restringido al grupo en el recibo. -->
    <record id="action_report_cash_internal_control" model="ir.actions.report">
        <field name="name">Control Interno de Efectivo</field>
        <field name="model">cash.receipt</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">cash_receipt_voucher.report_cash_internal_control</field>
        <field name="report_file">cash_receipt_voucher.report_cash_internal_control</field>
    </record>

    <template id="report_cash_internal_control">
        <t t-call="web.html_container">
            <t t-call="web.internal_layout">
                <div class="page" style="font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; font-size: 10px; color: #000;">

                    <t t-set="mode" t-value="currency_mode or 'all_mxn'"/>
                    <t t-set="consolidated" t-value="mode == 'all_mxn'"/>
                    <t t-set="mxn_cur" t-value="env.ref('base.MXN', raise_if_not_found=False) or env.company.currency_id"/>
                    <t t-set="mode_label" t-value="'Consolidado en MXN (tipo de cambio DOF de cada fecha)' if consolidated else ('Solo recibos en USD' if mode == 'usd' else 'Solo recibos en MXN')"/>

                    <div class="row border-bottom pb-2 mb-3" style="border-color:#000 !important;">
                        <div class="col-8">
                            <h4 class="text-uppercase mb-0" style="font-weight:800; letter-spacing:1px;">
                                Control Interno de Efectivo
                            </h4>
                            <div style="font-size:9px; color:#666;">Documento interno — no entregar al cliente</div>
                            <div style="font-size:9.5px; color:#1d4ed8; font-weight:700; margin-top:2px;">Montos en: <span t-esc="mode_label"/></div>
                        </div>
                        <div class="col-4 text-end" style="font-size:12px; color:#505050;">
                            Impreso: <span t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y %H:%M')"/>
                        </div>
                    </div>

                    <t t-set="total_official" t-value="0.0"/>
                    <t t-set="total_real" t-value="0.0"/>
                    <t t-set="total_diff" t-value="0.0"/>
                    <t t-set="rep_currency" t-value="mxn_cur if consolidated else (docs[:1].currency_id or env.company.currency_id)"/>

                    <table class="table table-sm" style="width:100%; font-size:9px; border-collapse:collapse;">
                        <thead>
                            <tr style="background-color:#2f2f2f; color:#fff;">
                                <th style="color:#fff;">Recibo</th>
                                <th style="color:#fff;">Pedido</th>
                                <th style="color:#fff;">Cliente</th>
                                <th style="color:#fff;">Fecha</th>
                                <th class="text-end" style="color:#fff;">Cobrado</th>
                                <th class="text-end" style="color:#fff;">A cuenta</th>
                                <th class="text-end" style="color:#fff;">En caja</th>
                                <th class="text-end" style="color:#fff;">Pendiente por cobrar</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="docs" t-as="doc">
                                <t t-set="r_cur" t-value="mxn_cur if consolidated else doc.currency_id"/>
                                <t t-set="r_official" t-value="doc.amount_mxn if consolidated else doc.amount"/>
                                <t t-set="r_account" t-value="doc.amount_internal_mxn if consolidated else doc.amount_internal"/>
                                <t t-set="r_caja" t-value="r_official - r_account"/>
                                <t t-set="r_pending" t-value="doc.partner_id.credit if r_cur == doc.company_id.currency_id else doc.company_id.currency_id._convert(doc.partner_id.credit, r_cur, doc.company_id, doc.date.date())"/>
                                <t t-set="total_official" t-value="total_official + r_official"/>
                                <t t-set="total_real" t-value="total_real + r_account"/>
                                <t t-set="total_diff" t-value="total_diff + r_caja"/>
                                <tr style="page-break-inside:avoid;">
                                    <td><strong t-field="doc.name"/></td>
                                    <td><span t-esc="', '.join(doc.sale_order_ids.mapped('name'))"/></td>
                                    <td><span t-field="doc.partner_id.name"/></td>
                                    <td><span t-field="doc.date" t-options="{'format': 'dd/MM/yyyy'}"/></td>
                                    <td class="text-end" style="white-space:nowrap;">
                                        <span t-esc="r_official" t-options="{'widget': 'monetary', 'display_currency': r_cur}"/>
                                    </td>
                                    <td class="text-end" style="white-space:nowrap;">
                                        <span t-esc="r_account" t-options="{'widget': 'monetary', 'display_currency': r_cur}"/>
                                    </td>
                                    <td class="text-end"
                                        t-attf-style="white-space:nowrap; font-weight:700; color:#{'d97706' if r_caja &gt; 0 else '2563eb' if r_caja &lt; 0 else '000'};">
                                        <span t-esc="r_caja" t-options="{'widget': 'monetary', 'display_currency': r_cur}"/>
                                    </td>
                                    <td class="text-end" style="white-space:nowrap;">
                                        <span t-esc="r_pending" t-options="{'widget': 'monetary', 'display_currency': r_cur}"/>
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                        <tfoot>
                            <tr style="background-color:#f2f2f2; font-weight:800;">
                                <td colspan="4" class="text-end text-uppercase" style="border:1px solid #d8d8d8;">Totales</td>
                                <td class="text-end" style="border:1px solid #d8d8d8; white-space:nowrap;">
                                    <span t-esc="total_official" t-options="{'widget': 'monetary', 'display_currency': rep_currency}"/>
                                </td>
                                <td class="text-end" style="border:1px solid #d8d8d8; white-space:nowrap;">
                                    <span t-esc="total_real" t-options="{'widget': 'monetary', 'display_currency': rep_currency}"/>
                                </td>
                                <td class="text-end" style="border:1px solid #d8d8d8; white-space:nowrap;">
                                    <span t-esc="total_diff" t-options="{'widget': 'monetary', 'display_currency': rep_currency}"/>
                                </td>
                                <td style="border:1px solid #d8d8d8;"/>
                            </tr>
                        </tfoot>
                    </table>

                    <div style="margin-top:18px; border:1px solid #ccc; padding:8px; background-color:#fafafa; font-size:9px; color:#555;">
                        <strong style="color:#333;">CONFIDENCIAL.</strong>
                        <b>Cobrado</b> = lo que pagó el cliente (único monto reflejado en el recibo,
                        el estado de cuenta y la contabilidad). <b>A cuenta</b> = lo depositado/registrado.
                        <b>En caja</b> = efectivo retenido (caja chica) = Cobrado − A cuenta.
                    </div>

                </div>
            </t>
        </t>
    </template>

</odoo>
